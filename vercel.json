{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "yarn build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "destination": "/app",
      "permanent": false
    },
    {
      "source": "/app/",
      "destination": "/app",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/app/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/app/manifest.webmanifest",
      "destination": "/manifest.webmanifest"
    },
    {
      "source": "/app/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/app/workbox-:path*",
      "destination": "/workbox-:path*"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/",
      "destination": "/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/index.html"
    }
  ]
}
